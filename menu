    local Old; Old = hookfunction(ShootModule, newcclosure(function(Self, ...)
        if Self then
            return Old(Self, ...)
        end

        local WeaponFlags = Legit.WeaponFlags

        if not WeaponFlags or not WeaponFlags["legit bullet redirection enabled"].Value then
            return Old(Self, ...)
        end

        if WeaponFlags["legit bullet redirection hit chance"].Value < Random(1, 100) then
            return Old(Self, ...)
        end

        local Target = Legit.GetSilentTarget({
            Fov = WeaponFlags["legit bullet redirection silent aim fov"].Value,
            Accuracy = WeaponFlags["legit bullet redirection accuracy"].Value,
            HitscanPoints = WeaponFlags["legit bullet redirection hitscan points"].Value,
            HitscanPriority = WeaponFlags["legit bullet redirection hitscan priority"].Value,
            CheckWall = true
        })

        if not Target then
            return Old(Self, ...)
        end

        local Arguments = {...}
        local Origin = Arguments[4]
        local Bullets = Arguments[5]

        local Goal = Legit.GetPointScalePosition(Target, WeaponFlags["legit bullet redirection point scale"].Value)

        if WeaponFlags["legit bullet redirection adjust for target movement"].Value then
            Goal = Mathematics.SolvePrediction(
                Origin, 
                Goal, 
                Target.Velocity, 
                LInfo.WeaponVelocity
            )
        end

        if WeaponFlags["legit bullet redirection adjust for bullet drop"].Value then
            Goal = Mathematics.SolveBulletDrop(
                Origin, 
                LInfo.WeaponAcceleration, 
                Goal, 
                LInfo.WeaponVelocity
            )
        end

        local SpreadMultiplier = ((Goal - Origin).Magnitude / 100) * WeaponFlags["legit bullet redirection spread"].Value / 10

        for i = 1, #Bullets do
            Bullets[i] = (Goal + (NewVector3(Random() * Random(-1, 1), Random() * Random(-1, 1), Random() * Random(-1, 1)).Unit * SpreadMultiplier) - Origin).Unit
        end

        return Old(Self, Unpack(Arguments))
    end))
end


