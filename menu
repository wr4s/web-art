        for Index, Value in next, Data.Chams do
            local BodyPart = Data.BodyParts[Index]
            local Inline, Outline = Value[1], Value[2]

            Inline.Adornee = BodyPart
            Inline.Transparency = InvisibleTransparency
            Inline.Color3 = InvisibleColor
            Inline.ZIndex = Glow and 1 or 1
            Inline.AlwaysOnTop = Glow or true
            Inline.Visible = true
            Inline.Shading = InlineShade

            Outline.Adornee = BodyPart
            Outline.Transparency = VisibleTransparency
            Outline.Color3 = VisibleColor
            Outline.ZIndex = Glow and -1 or 1
            Outline.AlwaysOnTop = Glow
            Outline.Visible = true
            Outline.Shading = OutlineShade
        end
    end

    --[[Esp.UpdateChamsGroup = function(Table, Visible)
        for i = 1, #Table do
            Esp.UpdateChamsPlayer(Table[i], Visible)
        end
    end]]

    Esp.UpdateChamsAll = function()
        for i = 1, Info.PlayersIndex do
            Esp.UpdateChamsPlayer(Info.Players[i], Flags["esp players chams"].Value)
        end
    end

    local LastStep = 0
    Esp.Step = function()
        local Time = Tick()
        local Delta = Time - LastStep

        if Delta < (1 / Flags["esp esp settings refresh rate"].Value) then
            return
        end

        LastStep = Time

        if not Flags["esp players enabled"].Value then
            for i = 1, Info.PlayersIndex do
                local Renders = Info.Players[i].Renders
                Renders.Framework.Visible = false
                Renders.Arrow.Visible = false

                for i = 1, 9 do
                    Renders[i].Visible = false
                end
            end

            return
        end

        local WTVP = Camera.WorldToViewportPoint

        local ShowBox = Flags["esp players bounding box"].Value
        local ShowFill = ShowBox and Flags["esp players filled bounding box"].Value
        local ShowHealth = Flags["esp players health bar"].Value
        local ShowName = Flags["esp players name"].Value
        local ShowWeapon = Flags["esp players held weapon"].Value
        local ShowDistance = Flags["esp players distance"].Value
        local ShowSkeleton = Flags["esp players skeleton"].Value
        local ShowRank = Flags["esp players rank"].Value
        local ShowArrow = Flags["esp players out of view"].Value

        local BoxColorpicker = ShowBox and Override or Flags["esp players bounding box color"]
        local BoxFillColorpicker = ShowFill and Flags["esp players filled bounding box color"]
        local HealthColorLow = ShowHealth and Flags["esp players health bar color low"]
        local HealthColorHigh = ShowHealth and Flags["esp players health bar color high"]
        local NameColorpicker = ShowName and Override or Flags["esp players name color"]
        local SkeletonColorpicker = ShowSkeleton and Flags["esp players skeleton color"]
        local ArrowColorpicker = ShowArrow and Override or Flags["esp players arrow color"]
        local ArrowDynamic = ShowArrow and Flags["esp players dynamic arrow size"].Value
        local ArrowSize = not ArrowDynamic and Flags["esp players arrow size"].Value

        local DrawDistance = Flags["esp esp settings maximum draw distance"].Value

        for i = 1, Info.PlayersIndex do
            local Data = Info.Players[i]

            if not Data.RootPosition or Data.Distance > DrawDistance then
                local Renders = Data.Renders
                Renders.Framework.Visible = false
                Renders.Arrow.Visible = false

                for i = 1, 9 do
                    Renders[i].Visible = false
                end

                continue
            end

            local Renders = Data.Renders
            local RootPosition = Data.RootPosition
            local Position, OnScreen = WTVP(RootPosition, true)

            local OverridePicker

            if Flags["esp esp settings highlight priorities"].Value and Data.Relation == "Priority" then
                OverridePicker = Flags["esp esp settings highlight priorities color"]
            elseif Flags["esp esp settings highlight friendlies"].Value and Data.Relation == "Friendly" then
                OverridePicker = Flags["esp esp settings highlight friendlies color"]
            end

            if not OnScreen then
                if not ShowArrow then
                    Renders.Framework.Visible = false
                    Renders.Arrow.Visible = false
                    for i = 1, 9 do
                        Renders[i].Visible = false
                    end

                    continue
                end

                local Relative = PointToObjectSpace(CurrentCamera.CFrame, RootPosition)
                local Angle = Atan2(-Relative.Y, Relative.X)
                local Rotation = Deg(Angle)
                local Radius = 350

                local Arrow = Renders.Arrow

                Arrow.ImageColor3 = (OverridePicker and OverridePicker.Color) or ArrowColorpicker.Color
                Arrow.ImageTransparency = ArrowColorpicker.Transparency
                Arrow.Position = NewUDim2(0, ScreenSizeX / 2 + Radius * Cos(Rad(Rotation)), 0, ScreenSizeY / 2 + Radius * Sin(Rad(Rotation)))
                Arrow.Rotation = Rotation + 90
                Arrow.Visible = true

                local Size = ArrowDynamic and Clamp(((Data.Distance - 1) / (100 - 1)) * (7 - 20) + 20, 7, 20) or ArrowSize
                Arrow.Size = NewUDim2(0, Size, 0, Size)
                
                Renders.Framework.Visible = false
                for i = 1, 9 do
                    Renders[i].Visible = false
                end
                continue
            end

            local RootUpVector = Data.RootCFrame.UpVector
            local Top = WTVP(RootPosition + RootUpVector * 1.5, false)
            local Bottom = WTVP(RootPosition - RootUpVector * 2.5, false)

            local Width = Abs(Top.X - Bottom.X)
            local Height = Max(Abs(Top.Y - Bottom.Y), Width)
            local SizeX = Floor(Max(Height / 2, Width * 2.5))

            local Framework = Renders.Framework
            Framework.Position = NewUDim2(0, Floor((Top.X + Bottom.X - SizeX) / 2), 0, Floor(Min(Top.Y, Bottom.Y)))
            Framework.Size = NewUDim2(0, SizeX, 0, Floor(Height))
            Framework.Visible = true

            if ShowBox then
                local Box, BoxInline, BoxOutline, BoxFill = Renders.Box, Renders.BoxInline, Renders.BoxOutline, Renders.BoxFill

                Box.Visible = true
                BoxInline.Enabled = true
                BoxInline.Color = (OverridePicker and OverridePicker.Color) or BoxColorpicker.Color
                BoxInline.Transparency = BoxColorpicker.Transparency

                BoxOutline.Enabled = true
                BoxOutline.Transparency = BoxColorpicker.Transparency

                if ShowFill then
                    BoxFill.Visible = true
                    BoxFill.BackgroundColor3 = BoxFillColorpicker.Color
                    BoxFill.BackgroundTransparency = BoxFillColorpicker.Transparency
                else
                    BoxFill.Visible = false
                end
            else
                Renders.Box.Visible = false
                Renders.BoxInline.Enabled = false
                Renders.BoxOutline.Enabled = false
            end

            if ShowHealth then
                local Percent = Data.Health / Data.MaxHealth

                Renders.HealthInline.Visible = true
                Renders.HealthInline.Size = NewUDim2(1, 0, Percent, 0)
                Renders.HealthInline.BackgroundColor3 = HealthColorLow.Color:Lerp(HealthColorHigh.Color, Percent)
                Renders.HealthOutline.Visible = true
            else
                Renders.HealthOutline.Visible = false
                Renders.HealthInline.Visible = false
            end

            if ShowName then
                local Name = Renders.Name
                local NameShadow = Renders.NameShadow

                Name.Visible = true
                Name.TextColor3 = (OverridePicker and OverridePicker.Color) or NameColorpicker.Color
                Name.TextTransparency = NameColorpicker.Transparency

                NameShadow.Visible = true
                NameShadow.TextTransparency = NameColorpicker.Transparency
            else
                Renders.Name.Visible = false
                Renders.NameShadow.Visible = false
            end

            if ShowWeapon and Data.Weapon then
                local Weapon = Renders.Weapon

                Weapon.Visible = true
                Weapon.Text = Data.Weapon
            else
                Renders.Weapon.Visible = false
            end

            if ShowDistance then
                local Distance = Renders.Distance

                Distance.Visible = true
                Distance.Text = (Floor(Data.Distance * 10 + 0.5) / 10) .. "M"
                Distance.Position = Renders.Weapon.Visible and NewUDim2(0.5, 0, 1, 14) or NewUDim2(0.5, 0, 1, 6)
            else
                Renders.Distance.Visible = false
            end

            if ShowRank then
                local Rank = Renders.Rank

                Rank.Visible = true
                Rank.Text = Data.Rank
            else
                Renders.Rank.Visible = false
            end

            if ShowSkeleton then
                local Joints = Data.Joints
                for i = 1, #Joints do
                    local PositionA = WTVP(PointToWorldSpace(Joints[i][1].CFrame, SkeletonOffsetsA[i]))
                    local PositionB = WTVP(PointToWorldSpace(Joints[i][2].CFrame, SkeletonOffsetsB[i]))

                    local Center = (NewVector2(PositionA.X, PositionA.Y) + NewVector2(PositionB.X, PositionB.Y)) / 2
                    local Offset = NewVector2(PositionB.X, PositionB.Y) - NewVector2(PositionA.X, PositionA.Y)

                    local Line = Renders[i]
                    Line.Position = NewUDim2(0, Center.X, 0, Center.Y)
                    Line.Size = NewUDim2(0, Offset.Magnitude, 0, 1)
                    Line.Rotation = Deg(Atan2(Offset.Y, Offset.X))
                    Line.BackgroundColor3 = (OverridePicker and OverridePicker.Color) or SkeletonColorpicker.Color
                    Line.Transparency = SkeletonColorpicker.Transparency
                    Line.Visible = true
                end
            else
                for i = 1, 9 do
                    Renders[i].Visible = false
                end
            end

            Renders.Arrow.Visible = false
        end
    end

    Esp.Load = function()
        Esp.StepConnection = RenderStepped:Connect(Esp.Step)

        Esp.Loaded = true
    end
end


-- Visuals
do
    local ArmNames = {["Right Arm"] = true, ["Left Arm"] = true}

    Visuals.Materials = {
		["Ghost"] = Enum.Material.ForceField,
		["Flat"] = Enum.Material.Neon,
		["Foil"] = Enum.Material.Foil,
		["Custom"] = Enum.Material.SmoothPlastic,
		["Reflective"] = Enum.Material.Glass
	}
    Visuals.OriginalLighting = {}

    local Properties = {"Ambient", "OutdoorAmbient", "Brightness", "GlobalShadows"}
    for i = 1, #Properties do
        local Property = Properties[i]

        Visuals.OriginalLighting[Property] = Lighting[Property]
    end

    Visuals.ApplyTool = function(Tool)
        if not Tool then return end

        local Children = GetChildren(Tool)
        for i = 1, #Children do
            local Child = Children[i]

            if Child.ClassName ~= "MeshPart" then
                continue
            end

            if Flags["esp view model weapon chams"].Value then
                local Colorpicker = Flags["esp view model weapon chams color"]
                Child.Color = Colorpicker.Color
                Child.Transparency = Colorpicker.Transparency

                Child.Material = Visuals.Materials[Flags["esp view model weapon chams material"].Value]
                Child.TextureID = ForceFieldAnimations[Flags["esp view model weapon chams animation"].Value]
            end
        end
    end

    Visuals.ApplyArm = function(Arm)
        if not Arm then return end

        local Colorpicker = Flags["esp view model arm chams color"]
        Arm.Color = Colorpicker.Color
        Arm.Transparency = Colorpicker.Transparency

        Arm.Material = Visuals.Materials[Flags["esp view model arm chams material"].Value]
    end

    Visuals.OnLightingChanged = function()
        if Flags["visuals world ambient"].Value then
            Lighting.Ambient = Flags["visuals world ambient indoor color"].Color
            Lighting.OutdoorAmbient = Flags["visuals world ambient outdoor color"].Color
        else
            Lighting.Ambient = Visuals.OriginalLighting.Ambient
            Lighting.OutdoorAmbient = Visuals.OriginalLighting.OutdoorAmbient
        end

        if Flags["visuals world force time"].Value then
            Lighting.ClockTime = Flags["visuals world time of day"].Value
        end

        if Flags["visuals world custom brightness"].Value then
            local BrightnessMode = Flags["visuals world brightness mode"].Value

            if BrightnessMode == "Dimmed" then -- TODO: Maybe remove this?
                Lighting.Brightness = Visuals.OriginalLighting.Brightness / 4
            elseif BrightnessMode == "Nightmode" then
                Lighting.Brightness = 0
            else -- Full bright
				Lighting.Brightness = 1
				Lighting.GlobalShadows = false
            end
        else
            Lighting.Brightness = Visuals.OriginalLighting.Brightness
            Lighting.GlobalShadows = Visuals.OriginalLighting.GlobalShadows
        end
    end

    Visuals.Load = function()
        -- Connections
        Lighting.LightingChanged:Connect(Visuals.OnLightingChanged)
        CurrentCamera.ChildAdded:Connect(function(Child) -- TODO: Apply to current
            if Child.Name ~= "ViewModel" or Child.ClassName ~= "Model" then return end

            Child.ChildAdded:Connect(function(ViewModelChild)
                if ViewModelChild.ClassName == "Tool" then
                    Visuals.ApplyTool(ViewModelChild)
                elseif ViewModelChild.ClassName == "Part" and ArmNames[ViewModelChild] then
                    Visuals.ApplyArm(ViewModelChild)
                end
            end)

            Visuals.ApplyTool(FindFirstChildOfClass(Child, "Tool"))
            Visuals.ApplyArm(FindFirstChild(Child, "Right Arm"))
            Visuals.ApplyArm(FindFirstChild(Child, "Left Arm"))
        end)

        -- Run whatever
        Lighting.LightingStyle = Enum.LightingStyle.Soft
        Lighting.PrioritizeLightingQuality = false
        Visuals.OnLightingChanged()

        Visuals.Loaded = true
    end
end


