        local Section = Menu.Window.Pages[5]:CreateSection({Name = "Grenade Helper", Side = 1, Length = 0.5}) do
            Section:CreateToggle({
                Name = "Enabled",
                Flag = "misc grenade helper enabled"
            }):CreateHotkey({
                Flag = "misc grenade helper hotkey",
                Mode = "On hotkey",
                Callback = function(Active) -- TODO: Check if we even have a nade
                    if not Active then
                        return
                    end

                    if not Flags["misc grenade helper enabled"].Value then
                        return
                    end

                    local ClosestPlayer, ClosestAngle = nil, 360

                    do
                        local CameraCFrame = CurrentCamera.CFrame
                        local CameraPosition = CameraCFrame.Position
                        local CameraLookVector = CameraCFrame.LookVector

                        local RadFov = Rad(Flags["misc grenade helper fov"].Value)

                        for i = 1, Info.PlayersIndex do
                            local Data = Info.Players[i]

                            if not Data.RootPosition then
                                continue
                            end

                            local Angle = Acos(Dot(CameraLookVector, (Data.RootPosition - CameraPosition).Unit)) * 2
                            
                            if Angle > RadFov or Angle > ClosestAngle then
                                continue
                            end

                            ClosestAngle = Angle
                            ClosestPlayer = Data
                        end
                    end

                    if not ClosestPlayer then
                        return
                    end

                    Wrap(function()
                        Wait()

                        local AimDot = NewInstance("Frame")
                        AimDot.Parent = Menu.Overlay
                        AimDot.Size = NewUDim2(0, 5, 0, 5)
                        AimDot.Position = NewUDim2(0.5, -50, 0.5, -50)
                        AimDot.BackgroundColor3 = Menu.Theme.Accent
                        AimDot.Visible = false

                        local Corner = NewInstance("UICorner")
                        Corner.Parent = AimDot
                        Corner.CornerRadius = UDim.new(1, 0)

                        local Stroke = NewInstance("UIStroke")
                        Stroke.Parent = AimDot
                        Stroke.Thickness = 1
                        Stroke.Color = NewRGB(0, 0, 0)

                        local Connection; Connection = RenderStepped:Connect(function(DeltaTime)
                            if not UserInputService:IsKeyDown(Flags["misc grenade helper hotkey"].Key) then
                                Connection:Disconnect()
                                Destroy(AimDot)
                                return
                            end

                            local Origin = LocalPlayer.Character.Head.Position
                            local Goal = ClosestPlayer.RootPosition - NewVector3(0, 3.5, 0)

                            if Flags["misc grenade helper adjust for target movement"].Value then
                                Goal = Mathematics.SolvePrediction(
                                    Origin,
                                    Goal,
                                    ClosestPlayer.RootPart.Velocity,
                                    150
                                )
                            end

                            local Velocity = Mathematics.ResolveGrenadeVelocity(Origin, Goal, 150, Workspace.Gravity * 0.55)
                            if not Velocity then
                                AimDot.Visible = false
                                return
                            end

                            if Flags["misc grenade helper automatic aim"].Value then
                                CurrentCamera.CFrame = CurrentCamera.CFrame:Lerp(
                                    NewCFrame(CurrentCamera.CFrame.Position, CurrentCamera.CFrame.Position + Velocity.Unit),
                                    Flags["misc grenade helper speed"].Value / 10 * DeltaTime
                                )
                            end

                            local Position, OnScreen = Camera.WorldToViewportPoint(Origin + Velocity.Unit * 9999, true)

                            if OnScreen then
                                AimDot.Position = NewUDim2(
                                    0, Position.X - (AimDot.AbsoluteSize.X / 2),
                                    0, Position.Y - (AimDot.AbsoluteSize.Y / 2)
                                )
                                AimDot.Visible = true
                            else
                                AimDot.Visible = false
                            end
                        end)
                    end)()
                end
            })

            Section:CreateSlider({
                Name = "Maximum FOV",
                Flag = "misc grenade helper fov",
                Suffix = "°",
                Value = 10,
                Minimum = 0,
                Maximum = 15
            })

            Section:CreateToggle({
