        Info.Players[Player.Name] = Data

        return Data
    end

    Info.RemovePlayer = function(Player)
        local Data = Info.Players[Player]

        for _, Render in next, Data.Renders do
            Destroy(Render)
        end

        for _, Cham in next, Data.Chams do
            Destroy(Cham[1])
            Destroy(Cham[2])
        end

        Info.Players[Player] = nil

        for i = 1, Info.PlayersIndex do
            if Info.Players[i] == Data then
                Remove(Info.Players, i)
                Info.PlayersIndex -= 1
                break
            end
        end
    end

    Info.Step = function()
        local DistanceOrigin = LInfo.RootPart and LInfo.RootPart.Position
        local PlayersList = Info.Players
        local PlayersIndex = Info.PlayersIndex

        for i = 1, PlayersIndex do
            local Data = PlayersList[i]

            if Data.Humanoid and Data.RootPart then
                Data.RootCFrame = Data.RootPart.CFrame
                Data.RootPosition = Data.RootPart.Position

                if DistanceOrigin then
                    Data.Distance = (DistanceOrigin - Data.RootPosition).Magnitude
                end
            end
        end

        local Time = Tick() -- TODO: Ignore sorting players that are our teammates
        if Time - Info.LastSort > 0.5 then
            for i = 1, PlayersIndex - 1 do
                local Player1 = PlayersList[i]
                local Rank1 = (Player1.Relation == "Priority" and 2) or 1

                for j = i + 1, PlayersIndex do
                    local Player2 = PlayersList[j]
                    local Rank2 = (Player2.Relation == "Priority" and 2) or 1

                    if Rank1 < Rank2 then
                        PlayersList[i], PlayersList[j] = PlayersList[j], PlayersList[i]
                        Rank1 = Rank2
                        Player1 = PlayersList[i]
                    end
                end
            end

            Info.LastSort = Time
        end
    end

    Info.Load = function()
        local PlayerList = Players:GetPlayers()
        for i = 2, #PlayerList do
            Info.AddPlayer(PlayerList[i])
        end

        PlayerAdded:Connect(function(Player)
            Info.AddPlayer(Player)
        end)

        PlayerRemoved:Connect(function(Player)
            Info.RemovePlayer(Player)
        end)

        Stepped:Connect(Info.Step)

        Info.Loaded = true
    end
end




