-- Debug
local function SafeWaitForChild(Parent, Timeout, Name)
    if not Parent then
        Menu:CreateNotification({Text = Format("[FATAL] %s's parent missing!\nreport this to syberia;\n%s", Name, Traceback()), LifeTime = 9e9, Color = NewRGB(255, 0, 0)})
        return nil
    end

    local Object = WaitForChild(Parent, Name, Timeout)

    if Object then
        return Object
    end

    Menu:CreateNotification({Text = Format("[FATAL] %s missing!\nreport this to syberia;\n%s", Name, Traceback()), LifeTime = 9e9, Color = NewRGB(255, 0, 0)})

    return nil
end

local function SafeWaitHierarchy(Parent, Timeout, ...)
    local Names = {...}

    for i = 1, #Names do
        Parent = SafeWaitForChild(Parent, Timeout, Names[i])

        if not Parent then
            return nil
        end
    end

    return Parent
end

local function GetTableIndexes(Table)
    local Indexes = {}
    local IndexesIndex = 0 -- LMAO

    for Index, _ in next, Table do
        IndexesIndex += 1
        Indexes[IndexesIndex] = Index
    end

    return Indexes, IndexesIndex
end

