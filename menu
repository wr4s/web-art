                        if ValidsIndex < 1 then
                            Menu:CreateNotification({Text = "no stock found", LifeTime = 2, Priority = -100})
                            return
                        end
                        
                        Menu:CreateNotification({Text = "found " .. tostring(ValidsIndex) .. " in stock", LifeTime = 2, Priority = -101})
                        
                        local Objects = {}
                        local ObjectsIndex = 0

                        for i = 1, ValidsIndex do
                            local Shop = Valids[i]
                            local Adornee

                            if Shop.Name == "ArmoryDealer" then
                                Adornee = FindFirstChild(Shop, "ArmoryMan")
                            else
                                Adornee = FindFirstChild(Shop, "DealerMan")
                            end

                            local Highlight = NewInstance("Highlight")
                            Highlight.Parent = Menu.Overlay
                            Highlight.Adornee = Adornee
                            Highlight.FillColor = NewRGB(53, 60, 108)
                            
                            ObjectsIndex += 1
                            Objects[ObjectsIndex] = Highlight
                        end 

                        Delay(10, function()
                            for i = ObjectsIndex, 1, -1 do
                                local Object = Remove(Objects, i)
                                Destroy(Object)
                            end
                        end)
                    end
                })

                local Seen = {}
                local Names = {}
                local NamesIndex = 0

                local ShopsList = GetChildren(Shops)
                for i = 1, #ShopsList do
                    local Shop = ShopsList[i]
                    local Stocks = FindFirstChild(Shop, "CurrentStocks")
                    if Stocks then
                        local StocksList = GetChildren(Stocks)
                        for k = 1, #StocksList do
                            local Name = StocksList[k].Name
                            if not Seen[Name] then
                                Seen[Name] = true
                                NamesIndex += 1
                                Names[NamesIndex] = Name
                            end
                        end
                    end
                end

                Sort(Names)

                for i = 1, NamesIndex do
                    Finder:AddOption(Names[i])
                end
            end
        end
