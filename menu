    Legit.Raycast = function(Origin, Goal, RayParams) -- TODO: Rename
        local Direction = Goal - Origin
        local DirectionUnit = Direction.Unit

        local CurrentOrigin = Origin
        local RemainingDistance = Direction.Magnitude

        while RemainingDistance > 0 do
            local Result = Raycast(Workspace, CurrentOrigin, DirectionUnit * RemainingDistance, RayParams)
            if not Result then
                return false
            end

            local HitPart = Result.Instance
            if HitPart and HitPart.CanCollide and HitPart.Transparency < 1 then
                return true, Result
            end

            RemainingDistance = RemainingDistance - (Result.Position - CurrentOrigin).Magnitude
            CurrentOrigin = Result.Position + DirectionUnit / 20
        end

        return false
    end

    Legit.TriggerbotRaycast = function(Origin, Goal, RayParams) -- TODO: Rename
        local Direction = Goal - Origin
        local DirectionUnit = Direction.Unit

        local CurrentOrigin = Origin
        local RemainingDistance = Direction.Magnitude

        while RemainingDistance > 0 do
            local Result = Raycast(Workspace, CurrentOrigin, DirectionUnit * RemainingDistance, RayParams)
            if not Result then
                return false
            end

            local HitPart = Result.Instance
            if HitPart and HitPart.Transparency < 1 then
                return true, Result
            end

            RemainingDistance = RemainingDistance - (Result.Position - CurrentOrigin).Magnitude
            CurrentOrigin = Result.Position + DirectionUnit / 20
        end

        return false
    end

    Legit.TranslatePoints = function(Points)
        local Temporary = {}

        for i = 1, #Points do
            local Point = Legit.Points[Points[i]]

            Move(Point, 1, #Point, #Temporary + 1, Temporary)
        end

        return Temporary
    end

    Legit.GetPointScalePosition = function(Bone, Scale)
        if Scale == 0 then
            return Bone.Position
        end

        local Factor = Scale / 200
        local Size = Legit.PointSizes[Bone.Name] -- Bone.Size -- Removed due to Head size being larger than the visual size

        return Bone.Position + NewVector3(
            (Random() * 2 - 1) * Size.X * Factor,
            (Random() * 2 - 1) * Size.Y * Factor,
            (Random() * 2 - 1) * Size.Z * Factor
        )
    end

    Legit.GetSilentTarget = function(Parameters) -- I want a separate function for silent aim because it only needs the hitbox
        local CameraCFrame = CurrentCamera.CFrame
        local CameraPosition = CameraCFrame.Position
        local CameraLookVector = CameraCFrame.LookVector
        
        local Enemies = {}
        local EnemiesIndex = 0
        local RadFov = Rad(Parameters.Fov)

        -- Filter all entities
        for i = 1, Info.PlayersIndex do
            local Data = Info.Players[i]
            local RootPosition = Data.RootPosition

            if not RootPosition or Data.IsForceField or Data.Relation == "Friendly" or Acos(Dot(CameraLookVector, (RootPosition - CameraPosition).Unit)) * 2 > RadFov then
                continue
            end

            EnemiesIndex += 1
            Enemies[EnemiesIndex] = Data
        end

        if EnemiesIndex < 1 then
            return
        end

        local Points = {}
        local PointsIndex = 0

        -- Get all the points from enemies
        local HitscanPoints = Legit.TranslatePoints(Parameters.HitscanPoints)
        local CheckWall = Parameters.CheckWall

        for i = 1, EnemiesIndex do
            local EnemyData = Enemies[i]
            local EnemyBodyParts = EnemyData.BodyParts

            for k = 1, #HitscanPoints do
                local Point = EnemyBodyParts[HitscanPoints[k]]

                if not Point then
                    continue
                end

                local PointPosition = Point.Position

                if CheckWall then
                    local Hit, Result = Legit.Raycast(CameraPosition, PointPosition, Legit.RayParams)

                    if Hit then
                        continue
                    end
                end

                PointsIndex += 1
                Points[PointsIndex] = {Point, Acos(Dot(CameraLookVector, (PointPosition - CameraPosition).Unit)) * 2} -- Doesn't really need the * 2
            end
        end

        if PointsIndex < 1 then
            return
        end

        -- Check if we can get a priority point
        local HitscanPriority = Legit.PriorityPoints[Parameters.HitscanPriority]

        if HitscanPriority and Parameters.Accuracy >= Random(1, 100) then
            local ClosestPoint, ClosestAngle = nil, 360

            for i = 1, PointsIndex do
                local Point = Points[i][1]
                local Angle = Points[i][2]

                if Point.Name == HitscanPriority and Angle < ClosestAngle then
                    ClosestAngle = Angle
                    ClosestPoint = Point
                end
            end

            if ClosestPoint then
                return ClosestPoint
            end
        end

        -- We didn't get priority so lets choose the closest point from the table
        local ClosestPoint, ClosestAngle = nil, 360

        for i = 1, PointsIndex do
            local Point = Points[i]
            local Angle = Point[2]

            if Angle < ClosestAngle then
                ClosestAngle = Angle
                ClosestPoint = Point[1]
            end
        end
    
        return ClosestPoint
    end

    Legit.ProcessAimAssist = function(DeltaTime)
        local WeaponConfig = LInfo.WeaponConfig
        local WeaponFlags = Legit.WeaponFlags

        if not WeaponConfig or not WeaponFlags then
            return
        end

        local IsMagnet = WeaponFlags["legit trigger bot magnet triggerbot"].Value and WeaponFlags["legit trigger bot enabled"].Value and WeaponFlags["legit trigger bot enabled key"].Value

        if (not IsMagnet) and (not WeaponFlags["legit aim assist enabled"].Value or not WeaponFlags["legit aim assist enabled key"].Value) then
            Legit.CurrentTarget = nil
            return
        end

        local CameraCFrame = CurrentCamera.CFrame
        local CameraPosition = CameraCFrame.Position
        local CameraLookVector = CameraCFrame.LookVector

        if Legit.CurrentTarget then
            local CurrentTarget = Legit.CurrentTarget
            local CurrentPart = CurrentTarget.Part
            local CurrentData = CurrentTarget.Data

            if CurrentData.RootPosition and (CurrentData == Legit.PreviousTarget.Data or Tick() - Legit.PreviousTarget.Tick > (WeaponFlags["legit aim assist enemy switching delay"].Value / 1000)) then
                local AimPosition = CurrentPart.Position

                if IsMagnet or WeaponFlags["legit aim assist wall check"].Value then
                    local Hit, Result = Legit.Raycast(CameraPosition, AimPosition, Legit.RayParams)

                    if Hit then
                        Legit.CurrentTarget = nil
                        return
                    end
                end

                if WeaponFlags["legit aim assist adjust for target movement"].Value then
                    AimPosition = Mathematics.SolvePrediction(
                        CameraPosition,
                        AimPosition,
                        CurrentPart.Velocity,
                        LInfo.WeaponVelocity
                    )
                end

                if WeaponFlags["legit aim assist adjust for bullet drop"].Value then
                    AimPosition = Mathematics.SolveBulletDrop(
                        CameraPosition,
                        LInfo.WeaponAcceleration,
                        AimPosition,
                        LInfo.WeaponVelocity
                    )
                end

                Legit.PreviousTarget.Data = CurrentTarget.Data
                Legit.PreviousTarget.Tick = Tick()

                local Smoothing
                local Speed = IsMagnet and WeaponFlags["legit trigger bot magnet speed"].Value or WeaponFlags["legit aim assist speed"].Value

                if WeaponFlags["legit aim assist smoothing"].Value == "linear" then
			        Smoothing = Speed / 10 * DeltaTime
                else
			        Smoothing = 1 - Exp(-Speed / 2 * DeltaTime * CurrentTarget.Angle)
                end

                CurrentCamera.CFrame = CameraCFrame:Lerp(CFrame.lookAt(CameraPosition, AimPosition), Smoothing)
                return
            end
        
            Legit.CurrentTarget = nil
            return
        end
        
        local Enemies = {}
        local EnemiesIndex = 0
        local RadFov = Rad(IsMagnet and WeaponFlags["legit trigger bot magnet fov"].Value or WeaponFlags["legit aim assist fov"].Value)

        -- Filter all entities
        for i = 1, Info.PlayersIndex do
            local Data = Info.Players[i]
            local RootPosition = Data.RootPosition

            if not RootPosition or Data.IsForceField or Data.Relation == "Friendly" or Acos(Dot(CameraLookVector, (RootPosition - CameraPosition).Unit)) * 2 > RadFov then
                continue
            end

            EnemiesIndex += 1
            Enemies[EnemiesIndex] = Data
        end

        if EnemiesIndex < 1 then
            return
        end

        local Points = {}
        local PointsIndex = 0

        -- Get all the points from enemies
        local HitscanPoints = Legit.TranslatePoints(IsMagnet and WeaponFlags["legit trigger bot triggerbot hitboxes"].Value or WeaponFlags["legit aim assist hitscan points"].Value)
        local CheckWall = IsMagnet or WeaponFlags["legit aim assist wall check"].Value

        for i = 1, EnemiesIndex do
            local EnemyData = Enemies[i]
            local EnemyBodyParts = EnemyData.BodyParts

            for k = 1, #HitscanPoints do
                local Point = EnemyBodyParts[HitscanPoints[k]]

                if not Point then
                    continue
                end

                local PointPosition = Point.Position

                if CheckWall then
                    local Hit, Result = Legit.Raycast(CameraPosition, PointPosition, Legit.RayParams)

                    if Hit then
                        continue
                    end
                end

                PointsIndex += 1
                Points[PointsIndex] = {
                    Part = Point,
                    --Name = Point.Name,
                    Data = EnemyData,
                    Angle = Acos(Dot(CameraLookVector, (PointPosition - CameraPosition).Unit)) * 2
                } -- Doesn't really need the * 2
            end
        end

        if PointsIndex < 1 then
            return
        end

        -- Check if we can get a priority point
        local HitscanPriority = Legit.PriorityPoints[IsMagnet and WeaponFlags["legit trigger bot magnet priority"].Value or WeaponFlags["legit aim assist hitscan priority"].Value]

        if HitscanPriority and (IsMagnet and WeaponFlags["legit trigger bot magnet accuracy"].Value or WeaponFlags["legit aim assist accuracy"].Value) >= Random(1, 100) then
            local ClosestPoint, ClosestAngle = nil, 360

            for i = 1, PointsIndex do
                local Point = Points[i]
                local Angle = Point.Angle

                if Point.Part.Name == HitscanPriority and Angle < ClosestAngle then
                    ClosestAngle = Angle
                    ClosestPoint = Point
                end
            end

            if ClosestPoint then
                Legit.CurrentTarget = ClosestPoint
                Legit.CurrentTarget.Tick = Tick()
                Legit.CurrentTarget.IsMagnet = IsMagnet
                return
            end
        end

        -- We didn't get priority so lets choose the closest point from the table
        local ClosestPoint, ClosestAngle = nil, 360

        for i = 1, PointsIndex do
            local Point = Points[i]
            local Angle = Point.Angle

            if Angle < ClosestAngle then
                ClosestAngle = Angle
                ClosestPoint = Point
            end
        end
    
        Legit.CurrentTarget = ClosestPoint
        Legit.CurrentTarget.Tick = Tick()
        Legit.CurrentTarget.IsMagnet = IsMagnet
    end

    local RayParams = RaycastParams.new()
    RayParams.FilterType = Enum.RaycastFilterType.Include
    RayParams.RespectCanCollide = false
    Legit.TriggerParams = RayParams

    Legit.ProcessTriggerBot = function()
        local WeaponFlags = Legit.WeaponFlags

        if not WeaponFlags or not WeaponFlags["legit trigger bot enabled"].Value or not WeaponFlags["legit trigger bot enabled key"].Value then
            return
        end

        local Points = {}
